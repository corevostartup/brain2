import Foundation

enum NativeOAuthSecretsLocal {
    static let googleOAuthClientID = "YOUR_CLIENT_ID.apps.googleusercontent.com"
    static let googleOAuthClientSecret = "YOUR_CLIENT_SECRET"

    /// Vazio = http://127.0.0.1:8765/ . Se na Google Cloud cadastrou http://localhost:8765/ , ponha essa string aqui.
    static let googleOAuthRedirectURI = ""
}
