//
//  Copie este ficheiro para NativeOAuthSecrets.Local.swift e preencha (não commite segredos).
//  Use o mesmo ID cliente Web e segredo que no projeto macOS (Firebase > Autenticação > Google).
//
//  Na Google Cloud Console > Credenciais > [o mesmo cliente Web]:
//  Em «URIs de redirecionamento autorizados» adicione EXACTAMENTE:
//    brain2auth://oauth-callback
//  (o esquema `brain2auth` está em OAuthURLScheme.plist)
//

import Foundation

enum NativeOAuthSecretsLocal {
    static let googleOAuthClientID = "SEU-ID-CLIENTE-WEB-FIREBASE.apps.googleusercontent.com"
    static let googleOAuthClientSecret = "GOCSPX-..."
    /// Deixe vazio para usar brain2auth://oauth-callback
    static let googleOAuthRedirectURI_iOS = ""
}
